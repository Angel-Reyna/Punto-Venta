NODE_ENV=development
LOG_LEVEL=info

PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos_senior_db?schema=public"
CORS_ORIGIN="http://localhost:5173"

# Refresh cookie policy. Use SameSite=none only with HTTPS and COOKIE_SECURE=true.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

JWT_ACCESS_SECRET="CHANGE_THIS_ACCESS_SECRET_MINIMUM_32_CHARACTERS_LONG"
JWT_REFRESH_SECRET="CHANGE_THIS_REFRESH_SECRET_MINIMUM_32_CHARACTERS_LONG"
TOKEN_HASH_PEPPER="CHANGE_THIS_TOKEN_HASH_PEPPER_MINIMUM_32_CHARS"
JWT_ACCESS_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=10

# Development seed only. In production, set a unique strong password and do not commit it.
SEED_ADMIN_EMAIL="admin@pos.local"
SEED_ADMIN_NAME="Administrador"
SEED_ADMIN_PASSWORD="Admin12345DevOnly"
SEED_DEMO_DATA=true
