{
  "name": "punta-venta-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:doctor": "node scripts/dev-doctor.js",
    "dev:e2e": "ts-node-dev --respawn --transpile-only src/server.ts",
    "format:check": "prettier --check eslint.config.mjs package.json tsconfig.json jest.config.js",
    "lint": "eslint src tests jest.config.js",
    "predev": "node scripts/preflight-dev.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "seed": "ts-node-dev --transpile-only --exit-child src/scripts/seed.ts",
    "seed:e2e": "ts-node-dev --transpile-only --exit-child src/scripts/seed-e2e.ts",
    "seed:prod": "node dist/scripts/seed.js",
    "start": "node dist/server.js",
    "test": "jest",
    "test:critical": "jest critical-routes.permissions.test.ts auth.middleware.test.ts auth.service.test.ts cookieSecurity.test.ts sales.service.test.ts inventory.service.test.ts inventory.queries.test.ts products.import.test.ts products.delete.test.ts products.status.test.ts reports.service.test.ts security.redaction.test.ts --runInBand",
    "typecheck": "tsc --noEmit",
    "seed:demo-usage": "ts-node-dev --transpile-only --exit-child src/scripts/seed-demo-usage.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "pdfkit": "^0.16.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.0",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.0"
  },
  "overrides": {
    "qs": "6.15.2",
    "tmp": "0.2.6",
    "uuid": "11.1.1"
  }
}
