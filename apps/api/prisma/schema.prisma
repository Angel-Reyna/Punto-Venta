generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CASHIER
}

enum InventoryType {
  IN
  OUT
  ADJUSTMENT
  SALE
  RETURN
}

enum WarehouseType {
  STORAGE
  SELLER
}

enum InventoryTransferRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum InventoryReasonType {
  EXPIRATION
  OTHER
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum SaleAdjustmentRequestType {
  CANCEL_SALE
  RETURN_ITEMS
}

enum SaleAdjustmentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SellerAction {
  SELLER_LOGIN
  SELLER_LOGOUT
  SALE_CREATED
  SALE_VIEWED
  PRODUCT_VIEWED
  FAILED_ACCESS_ATTEMPT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales                Sale[]
  saleReturns          SaleReturn[]
  salesAdjustmentRequests         SaleAdjustmentRequest[] @relation("SalesAdjustmentRequestsRequested")
  reviewedSalesAdjustmentRequests SaleAdjustmentRequest[] @relation("SalesAdjustmentRequestsReviewed")
  inventoryTransferRequests       InventoryTransferRequest[] @relation("InventoryTransferRequestsRequested")
  reviewedInventoryTransferRequests InventoryTransferRequest[] @relation("InventoryTransferRequestsReviewed")
  audits               AuditLog[]
  sessions             RefreshSession[]
  sellerLogs           SellerActivityLog[]
  sellerWarehouse      Warehouse? @relation("SellerWarehouse")

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model RefreshSession {
  id                  String    @id @default(uuid())
  userId              String
  tokenHash           String    @unique
  userAgent           String?
  ipAddress           String?
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedBySessionId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model SellerActivityLog {
  id          String       @id @default(uuid())
  sellerId    String
  action      SellerAction
  entityType  String
  entityId    String?
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime     @default(now())

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model ProductCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([isActive])
}

model Product {
  id           String   @id @default(uuid())
  categoryId   String?
  sku          String   @unique
  barcode      String?  @unique
  name         String
  description  String?
  costPrice    Decimal  @db.Decimal(12, 2)
  salePrice    Decimal  @db.Decimal(12, 2)
  promoPercent Decimal  @default(0) @db.Decimal(5, 2)
  minStock     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category       ProductCategory?    @relation(fields: [categoryId], references: [id])
  saleItems          SaleItem[]
  saleReturnItems    SaleReturnItem[]
  adjustmentRequestItems SaleAdjustmentRequestItem[]
  inventoryTransferRequestItems InventoryTransferRequestItem[]
  inventoryMoves     InventoryMovement[]
  inventoryBalances  InventoryBalance[]

  @@index([categoryId])
  @@index([isActive])
  @@index([name])
  @@index([createdAt])
}

model Warehouse {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  type        WarehouseType @default(STORAGE)
  sellerId    String?       @unique
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller             User?               @relation("SellerWarehouse", fields: [sellerId], references: [id], onDelete: SetNull)
  inventoryMoves     InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  transferRequestsFrom InventoryTransferRequest[] @relation("InventoryTransferRequestsFrom")
  transferRequestsTo   InventoryTransferRequest[] @relation("InventoryTransferRequestsTo")
  sales                Sale[]

  @@index([isActive])
  @@index([type])
  @@index([type, isActive])
}


model InventoryTransferRequest {
  id              String                         @id @default(uuid())
  status          InventoryTransferRequestStatus @default(PENDING)
  fromWarehouseId String
  toWarehouseId   String
  requestedById   String
  reviewedById    String?
  reason          String
  reviewNote      String?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  reviewedAt      DateTime?

  fromWarehouse Warehouse @relation("InventoryTransferRequestsFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("InventoryTransferRequestsTo", fields: [toWarehouseId], references: [id])
  requestedBy   User      @relation("InventoryTransferRequestsRequested", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy    User?     @relation("InventoryTransferRequestsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)
  items         InventoryTransferRequestItem[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model InventoryTransferRequestItem {
  id          String @id @default(uuid())
  requestId   String
  productId   String?
  productSku  String
  productName String
  quantity    Int

  request InventoryTransferRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product Product?                 @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([productId])
}

model InventoryBalance {
  id          String   @id @default(uuid())
  productId   String
  warehouseId String
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([quantity])
  @@index([warehouseId, quantity])
}

model InventoryMovement {
  id          String        @id @default(uuid())
  productId   String?
  productSku  String
  productName String
  warehouseId String?
  type        InventoryType
  quantity    Int
  reason      String?
  reasonType  InventoryReasonType @default(OTHER)
  unitCostAtMovement Decimal? @db.Decimal(12, 2)
  costAmount  Decimal? @db.Decimal(12, 2)
  createdBy   String
  createdAt   DateTime      @default(now())

  product   Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([type])
  @@index([reasonType])
  @@index([reasonType, createdAt])
  @@index([createdBy])
  @@index([createdAt])
  @@index([type, createdAt])
  @@index([productId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([createdBy, createdAt])
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([isActive])
}

model Sale {
  id         String     @id @default(uuid())
  folio      String     @unique
  cashierId  String
  customerId String?
  warehouseId String?
  status     SaleStatus @default(COMPLETED)
  subtotal   Decimal    @db.Decimal(12, 2)
  discount   Decimal    @default(0) @db.Decimal(12, 2)
  tax        Decimal    @default(0) @db.Decimal(12, 2)
  total      Decimal    @db.Decimal(12, 2)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  cashier  User       @relation(fields: [cashierId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  items         SaleItem[]
  payments      Payment[]
  returns       SaleReturn[]
  adjustmentRequests SaleAdjustmentRequest[]

  @@index([cashierId])
  @@index([customerId])
  @@index([warehouseId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([cashierId, createdAt])
  @@index([cashierId, status, createdAt])
  @@index([warehouseId, createdAt])
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String?
  productSku  String
  productName String
  quantity    Int
  unitPrice    Decimal @db.Decimal(12, 2)
  unitCost     Decimal @default(0) @db.Decimal(12, 2)
  promoPercent Decimal @default(0) @db.Decimal(5, 2)
  discount     Decimal @default(0) @db.Decimal(12, 2)
  total        Decimal @db.Decimal(12, 2)
  grossProfit  Decimal @default(0) @db.Decimal(12, 2)

  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  returnItems SaleReturnItem[]
  adjustmentRequestItems SaleAdjustmentRequestItem[]

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(uuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  createdAt DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([method])
  @@index([createdAt])
}

model SaleReturn {
  id           String        @id @default(uuid())
  saleId       String
  cashierId    String
  reason       String
  refundMethod PaymentMethod
  refundTotal  Decimal       @db.Decimal(12, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sale          Sale             @relation(fields: [saleId], references: [id])
  cashier       User             @relation(fields: [cashierId], references: [id])
  items         SaleReturnItem[]

  @@index([saleId])
  @@index([cashierId])
  @@index([refundMethod])
  @@index([createdAt])
  @@index([saleId, createdAt])
  @@index([cashierId, createdAt])
  @@index([refundMethod, createdAt])
}

model SaleReturnItem {
  id          String  @id @default(uuid())
  returnId    String
  saleItemId  String
  productId   String?
  productSku  String
  productName String
  quantity    Int
  unitPrice    Decimal @db.Decimal(12, 2)
  unitCost     Decimal @default(0) @db.Decimal(12, 2)
  promoPercent Decimal @default(0) @db.Decimal(5, 2)
  discount     Decimal @default(0) @db.Decimal(12, 2)
  total        Decimal @db.Decimal(12, 2)
  grossProfit  Decimal @default(0) @db.Decimal(12, 2)

  return   SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItem SaleItem   @relation(fields: [saleItemId], references: [id])
  product  Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([returnId])
  @@index([saleItemId])
  @@index([productId])
}


model SaleAdjustmentRequest {
  id           String                      @id @default(uuid())
  type         SaleAdjustmentRequestType
  status       SaleAdjustmentRequestStatus @default(PENDING)
  saleId       String
  requestedById String
  reviewedById  String?
  reason       String
  reviewNote   String?
  refundMethod PaymentMethod?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  reviewedAt   DateTime?

  sale        Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  requestedBy User  @relation("SalesAdjustmentRequestsRequested", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User? @relation("SalesAdjustmentRequestsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)
  items       SaleAdjustmentRequestItem[]

  @@index([saleId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model SaleAdjustmentRequestItem {
  id          String @id @default(uuid())
  requestId   String
  saleItemId  String
  productId   String?
  productSku  String
  productName String
  quantity    Int

  request  SaleAdjustmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  saleItem SaleItem              @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  product  Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([saleItemId])
  @@index([productId])
}


model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  tableName String
  recordId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([tableName])
  @@index([recordId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([tableName, createdAt])
}
