# Copia este archivo como .env en la raíz solo para desarrollo local con Docker Compose.
# No uses estos secretos en producción.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pos_senior_db
POSTGRES_PORT=5432

API_NODE_ENV=development
API_PORT=4000
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/pos_senior_db?schema=public
CORS_ORIGIN=http://localhost:8080
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_32_chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_32_chars
TOKEN_HASH_PEPPER=dev_token_pepper_change_me_min_32_chars
JWT_ACCESS_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=10

SEED_ADMIN_EMAIL=admin@pos.local
SEED_ADMIN_NAME=Administrador
SEED_ADMIN_PASSWORD=Admin12345DevOnly
SEED_DEMO_DATA=true

WEB_PORT=8080
VITE_API_URL=/api

PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=Admin12345
PGADMIN_PORT=5050
